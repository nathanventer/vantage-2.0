# Copy to .env.local and fill in. .env.local is gitignored (*.local).
# Client-safe values only — NEVER put the Supabase service-role key here.

VITE_SUPABASE_URL=https://qzckmlhaoehsngxjlgfk.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# mock (default, offline demo + CI) | supabase (live backend)
VITE_DATA_BACKEND=mock

# off (default, sandbox adapters) | on (edge-backed payment/compliance/notifier)
VITE_EDGE_LIVE=off

# ── E2E (Playwright, optional) ─────────────────────────────────────────────
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:8080
# PLAYWRIGHT_SKIP_WEBSERVER=1
# VITE_DATA_BACKEND=supabase   # required for scenarios 1–3

# ── Live deploy (Vercel) ───────────────────────────────────────────────────
# vercel.json pins the same Supabase + edge settings as a typical .env.local so
# https://demo-theta-flax.vercel.app matches localhost:8080.
# Override in the Vercel dashboard only if you need a different project/key.
# Optional:
#   VITE_DEMO_LOGINS=off         # hide demo account switcher (default: ON)
